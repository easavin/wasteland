# Wasteland Chronicles - Environment Variables
# Copy to .env and fill in real values. NEVER commit .env

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/wasteland?sslmode=require

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Game Config
FREE_TURNS_PER_DAY=10
PREMIUM_PRICE_STARS=150
PREMIUM_DURATION_DAYS=30

# Admin Dashboard
ADMIN_JWT_SECRET=generate_a_random_64_char_string_here
ADMIN_API_SECRET=another_random_64_char_string_here

# Logging
LOG_LEVEL=INFO
